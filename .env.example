# URL publique du site (utilisée pour canonical, sitemap, Open Graph).
NEXT_PUBLIC_SITE_URL=https://budgio.fr

# Analytics — optionnels. Sans ID, aucun script n'est chargé (no-op).
# Google Analytics 4 — format G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# Microsoft Clarity — identifiant de projet (10 caractères)
NEXT_PUBLIC_CLARITY_ID=
# Plausible — domaine (si utilisé)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
